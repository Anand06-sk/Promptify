          font-size: 1.3rem;
        }
      }

      /* Password Reset Modal */
      .password-reset-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        animation: fadeIn 0.3s ease;
      }

      .password-reset-overlay.active {
        display: flex;
      }

      .password-reset-modal {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(var(--glass-blur));
        -webkit-backdrop-filter: blur(var(--glass-blur));
        box-shadow: var(--glass-shadow);
        border-radius: 20px;
        padding: 32px;
        width: 90%;
        max-width: 400px;
        animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .password-reset-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
      }

      .password-reset-header i {
        font-size: 1.8rem;
        color: var(--purple);
        background: rgba(167, 139, 250, 0.15);
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
      }

      .password-reset-header-text h2 {
        font-family: var(--font-display);
        font-size: 1.3rem;
        font-weight: 600;
        margin: 0 0 4px 0;
      }

      .password-reset-header-text p {
        color: var(--text-soft);
        font-size: 0.85rem;
        margin: 0;
      }

      .password-reset-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      .password-reset-input {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid var(--border-color);
        border-radius: 12px;
        background: var(--surface);
        color: var(--text);
        font-size: 0.95rem;
        transition: all var(--transition);
      }

      .password-reset-input:focus {
        outline: none;
        border-color: var(--purple);
        box-shadow: 0 0 0 3px rgba(167, 139, 250, 0.1);
      }

      .password-reset-error {
        background: rgba(239, 68, 68, 0.1);
        color: #dc2626;
        padding: 10px 12px;
        border-radius: 8px;
        font-size: 0.85rem;
        display: none;
        border-left: 3px solid #dc2626;
      }

      .password-reset-error.show {
        display: block;
      }

      .password-reset-success {
        background: rgba(16, 185, 129, 0.1);
        color: #059669;
        padding: 10px 12px;
        border-radius: 8px;
        font-size: 0.85rem;
        display: none;
        border-left: 3px solid #10b981;
        text-align: center;
      }

      .password-reset-success.show {
        display: block;
      }

      .password-reset-buttons {
        display: flex;
        gap: 12px;
      }

      .password-reset-btn {
        flex: 1;
        padding: 12px;
        border-radius: 12px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        transition: all var(--transition);
        font-size: 0.95rem;
      }

      .password-reset-btn-primary {
        background: var(--grad-brand);
        color: white;
        box-shadow: 0 8px 24px rgba(167, 139, 250, 0.35);
      }

      .password-reset-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 28px rgba(167, 139, 250, 0.45);
      }

      .password-reset-btn-primary:active {
        transform: scale(0.98);
      }

      .password-reset-btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
      }

      .password-reset-btn-secondary {
        background: var(--surface-alt);
        color: var(--text);
        border: 1px solid var(--border-color);
      }

      .password-reset-btn-secondary:hover {
        background: var(--surface);
      }

      @media (max-width: 640px) {
        .password-reset-modal {
          width: 95%;
          padding: 24px;
        }
      }
    </style>
  </head>
  <body>
    <div class="bg-mesh" aria-hidden="true">
      <span class="blob blob-1"></span>
      <span class="blob blob-2"></span>
      <span class="blob blob-3"></span>
    </div>

    <div class="auth-wrapper">
      <div class="auth-container">
        <div class="auth-card">
          <div class="auth-header">
            <div class="auth-logo">
              <i class="fa-solid fa-wand-magic-sparkles"></i>
              <span>PromptVerse</span>
            </div>
            <h1 class="auth-title" id="authTitle">Welcome back</h1>
            <p class="auth-subtitle">
              Sign in to access your personalized gallery
            </p>
          </div>

          <div class="auth-tabs">
            <button class="auth-tab-btn active" data-tab="login">Login</button>
            <button class="auth-tab-btn" data-tab="signup">Sign Up</button>
          </div>

          <form class="auth-form active" id="loginForm" data-tab="login">
            <div class="form-group">
              <label class="form-label" for="loginEmail">Email</label>
              <input
                type="email"
                id="loginEmail"
                class="form-input"
                placeholder="you@example.com"
                required
              />
              <div class="form-error" id="loginEmailError"></div>
            </div>

            <div class="form-group">
              <label class="form-label" for="loginPassword">Password</label>
              <input
                type="password"
                id="loginPassword"
                class="form-input"
                placeholder="••••••••"
                required
              />
              <div class="form-error" id="loginPasswordError"></div>
            </div>

            <div class="form-options">
              <div class="checkbox-wrapper">
                <input type="checkbox" id="rememberMe" />
                <label class="checkbox-label" for="rememberMe"
                  >Remember me</label
                >
              </div>
              <a class="form-link" href="#">Forgot password?</a>
            </div>

            <button type="submit" class="auth-btn auth-btn-primary">
              Sign In
            </button>

            <div class="auth-divider">or</div>

            <div class="social-login">
              <button
                type="button"
                class="social-btn"
                id="googleLoginBtn"
                title="Sign in with Google"
              >
                <i class="fa-brands fa-google"></i>
                <span style="font-size: 0.85rem">Google</span>
              </button>
            </div>

            <div class="auth-footer">
              Don't have an account?
              <a href="#" class="switch-tab" data-tab="signup">Create one</a>
            </div>
          </form>

          <form class="auth-form" id="signupForm" data-tab="signup">
            <div class="form-group">
              <label class="form-label" for="signupUsername">Username</label>
              <input
                type="text"
                id="signupUsername"
                class="form-input"
                placeholder="your_username"
                required
              />
              <div class="form-error" id="signupUsernameError"></div>
            </div>

            <div class="form-group">
              <label class="form-label" for="signupEmail">Email</label>
              <input
                type="email"
                id="signupEmail"
                class="form-input"
                placeholder="you@example.com"
                required
              />
              <div class="form-error" id="signupEmailError"></div>
            </div>

            <div class="form-group">
              <label class="form-label" for="signupPassword">Password</label>
              <input
                type="password"
                id="signupPassword"
                class="form-input"
                placeholder="••••••••"
                required
              />
              <div class="form-error" id="signupPasswordError"></div>
            </div>

            <div class="form-group">
              <label class="form-label" for="signupConfirm"
                >Confirm Password</label
              >
              <input
                type="password"
                id="signupConfirm"
                class="form-input"
                placeholder="••••••••"
                required
              />
              <div class="form-error" id="signupConfirmError"></div>
            </div>

            <div class="checkbox-wrapper" style="margin-bottom: 20px">
              <input type="checkbox" id="termsAccept" required />
              <label class="checkbox-label" for="termsAccept"
                >I agree to the
                <a class="form-link" href="#">Terms of Service</a></label
              >
              <div class="form-error" id="signupTermsError"></div>
            </div>

            <button type="submit" class="auth-btn auth-btn-primary">
              Create Account
            </button>

            <div class="auth-divider">or</div>

            <div class="social-login">
              <button
                type="button"
                class="social-btn"
                id="googleSignupBtn"
                title="Sign up with Google"
              >
                <i class="fa-brands fa-google"></i>
                <span style="font-size: 0.85rem">Google</span>
              </button>
            </div>

            <div class="auth-footer">
              Already have an account?
              <a href="#" class="switch-tab" data-tab="login">Sign in</a>
            </div>
          </form>

          <div class="back-home">
            <a href="index.html"
              ><i class="fa-solid fa-arrow-left"></i> Back to home</a
            >
          </div>
        </div>
      </div>
    </div>

    <!-- Password Reset Modal -->
      <div class="password-reset-modal">
        <div class="password-reset-header">
          <i class="fa-solid fa-lock"></i>
          <div class="password-reset-header-text">
            <h2>Reset Password</h2>
            <p>Enter your email to receive a reset link</p>
          </div>
        </div>

        <div class="password-reset-form">
          <input
            type="email"
            id="passwordResetEmail"
            class="password-reset-input"
            placeholder="your@email.com"
            autocomplete="email"
          />
          <div class="password-reset-error" id="passwordResetError"></div>
          <div class="password-reset-success" id="passwordResetSuccess">
            <i class="fa-solid fa-check-circle"></i> Check your email for the
            reset link!
          </div>
          <div class="password-reset-buttons">
            <button class="password-reset-btn password-reset-btn-primary" id="sendResetBtn">
              <i class="fa-solid fa-paper-plane"></i> Send Reset Link
            </button>
            <button class="password-reset-btn password-reset-btn-secondary" id="closeResetBtn">
              <i class="fa-solid fa-xmark"></i> Close
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Password Reset Modal -->
    <div id="passwordResetModal" class="password-reset-modal" style="display: none">
      <div class="password-reset-overlay"></div>
      <div class="password-reset-card">
        <button
          class="password-reset-close"
          id="closePasswordResetBtn"
          aria-label="Close"
        >
          <i class="fa-solid fa-xmark"></i>
        </button>

        <div class="password-reset-header">
          <i class="fa-solid fa-lock"></i>
          <h2>Reset Your Password</h2>
          <p>Enter your email and we'll send you a reset link</p>
        </div>

        <form id="passwordResetForm" class="password-reset-form">
          <div class="form-group">
            <label class="form-label" for="resetEmail">Email Address</label>
            <input
              type="email"
              id="resetEmail"
              class="form-input"
              placeholder="you@example.com"
              required
            />
            <div class="form-error" id="resetEmailError"></div>
          </div>

          <button
            type="submit"
            class="auth-btn auth-btn-primary"
            id="resetSubmitBtn"
          >
            Send Reset Link
          </button>
        </form>

        <div
          id="resetSuccessMessage"
          class="password-reset-success"
          style="display: none"
        >
          <i class="fa-solid fa-check-circle"></i>
          <h3>Email Sent!</h3>
          <p id="resetSuccessText">
            Check your inbox for a password reset link. It may take a few
            minutes to arrive. <strong>Check your spam folder too!</strong>
          </p>
          <button
            class="auth-btn auth-btn-primary"
            id="resetDoneBtn"
            style="margin-top: 16px"
          >
            Back to Login
          </button>
        </div>

        <div class="password-reset-footer">
          Remember your password?
          <a href="#" class="form-link" id="backToLoginBtn">Sign in</a>
        </div>
      </div>
    </div>

    <script type="module">
      import {
        loginWithGoogle,
        loginWithEmail,
        signupWithEmail,
        resendVerificationEmail,
        resetPassword,
      } from "./auth.js";
      import { getFriendlyErrorMessage } from "./user-service.js";

      class AuthManager {
        constructor() {
          this.currentTab = "login";
          this.init();
        }

        init() {
          this.setupTabSwitching();
          this.setupFormHandlers();
          this.setupSocialButtons();
          this.setupPasswordReset();
        }

        setupTabSwitching() {
          document.querySelectorAll(".auth-tab-btn").forEach((btn) => {
            btn.addEventListener("click", (e) => {
              e.preventDefault();
              const tab = btn.dataset.tab;
              this.switchTab(tab);
            });
          });

          document.querySelectorAll(".switch-tab").forEach((link) => {
            link.addEventListener("click", (e) => {
              e.preventDefault();
              const tab = link.dataset.tab;
              this.switchTab(tab);
            });
          });
        }

        switchTab(tab) {
          this.currentTab = tab;
          const title = tab === "login" ? "Welcome back" : "Join PromptVerse";
          document.getElementById("authTitle").textContent = title;

          document.querySelectorAll(".auth-tab-btn").forEach((btn) => {
            btn.classList.toggle("active", btn.dataset.tab === tab);
          });

          document.querySelectorAll(".auth-form").forEach((form) => {
            form.classList.toggle("active", form.dataset.tab === tab);
          });
        }

        setupFormHandlers() {
          document
            .getElementById("loginForm")
            .addEventListener("submit", (e) => this.handleLogin(e));
          document
            .getElementById("signupForm")
            .addEventListener("submit", (e) => this.handleSignup(e));
        }

        validateEmail(email) {
          const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          return re.test(email);
        }

        async handleLogin(e) {
          e.preventDefault();
          this.clearErrors("login");

          const email = document.getElementById("loginEmail").value.trim();
          const password = document.getElementById("loginPassword").value;

          let valid = true;

          if (!email) {
            this.showError("loginEmailError", "Email is required");
            valid = false;
          } else if (!this.validateEmail(email)) {
            this.showError("loginEmailError", "Invalid email address");
            valid = false;
          }

          if (!password) {
            this.showError("loginPasswordError", "Password is required");
            valid = false;
          } else if (password.length < 6) {
            this.showError(
              "loginPasswordError",
              "Password must be at least 6 characters",
            );
            valid = false;
          }

          if (valid) {
            try {
              const firebaseUser = await loginWithEmail(email, password);
              this.completeLogin(firebaseUser);
            } catch (error) {
              const friendlyMessage = getFriendlyErrorMessage(error);
              this.showError("loginPasswordError", friendlyMessage);
            }
          }
        }

        async handleSignup(e) {
          e.preventDefault();
          this.clearErrors("signup");

          const username = document
            .getElementById("signupUsername")
            .value.trim();
          const email = document.getElementById("signupEmail").value.trim();
          const password = document.getElementById("signupPassword").value;
          const confirm = document.getElementById("signupConfirm").value;
          const termsAccept = document.getElementById("termsAccept").checked;

          let valid = true;

          if (!username) {
            this.showError("signupUsernameError", "Username is required");
            valid = false;
          } else if (username.length < 3) {
            this.showError(
              "signupUsernameError",
              "Username must be at least 3 characters",
            );
            valid = false;
          }

          if (!email) {
            this.showError("signupEmailError", "Email is required");
            valid = false;
          } else if (!this.validateEmail(email)) {
            this.showError("signupEmailError", "Invalid email address");
            valid = false;
          }

          if (!password) {
            this.showError("signupPasswordError", "Password is required");
            valid = false;
          } else if (password.length < 8) {
            this.showError(
              "signupPasswordError",
              "Password must be at least 8 characters",
            );
            valid = false;
          }

          if (password !== confirm) {
            this.showError("signupConfirmError", "Passwords do not match");
            valid = false;
          }

          if (!termsAccept) {
            this.showError(
              "signupTermsError",
              "You must accept the Terms of Service",
            );
            valid = false;
          }

          if (valid) {
            try {
              const firebaseUser = await signupWithEmail(
                email,
                password,
                username,
              );
              // Show verification notice before redirecting
              this.showVerificationNotice();
              // Redirect after 3 seconds
              setTimeout(() => {
                this.completeLogin(firebaseUser);
              }, 3000);
            } catch (error) {
              const friendlyMessage = getFriendlyErrorMessage(error);
              this.showError("signupEmailError", friendlyMessage);
            }
          }
        }

        completeLogin(firebaseUser) {
          // Firebase authentication is handled in auth.js
          // Redirect to next page or home
          const params = new URLSearchParams(window.location.search);
          const next = params.get("next") || "index.html";
          const action = params.get("action");
          const id = params.get("id");

          if (action === "bookmark" && id) {
            const current = JSON.parse(
              localStorage.getItem("pv_bookmarks") || "[]",
            );
            if (!current.includes(id)) current.push(id);
            localStorage.setItem("pv_bookmarks", JSON.stringify(current));
          }

          window.location.href = next;
        }

        showVerificationNotice() {
          // Show a temporary banner about email verification
          const noticeId = "email-verification-notice";
          let notice = document.getElementById(noticeId);

          if (!notice) {
            notice = document.createElement("div");
            notice.id = noticeId;
            notice.style.cssText = `
              position: fixed;
              top: 20px;
              left: 50%;
              transform: translateX(-50%);
              background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
              color: white;
              padding: 16px 24px;
              border-radius: 12px;
              z-index: 9999;
              box-shadow: 0 8px 24px rgba(102, 126, 234, 0.4);
              max-width: 90%;
              font-size: 0.95rem;
              font-weight: 500;
            `;
            notice.innerHTML = `<i class="fa-solid fa-envelope" style="margin-right: 8px;"></i> Verification email sent! Check your inbox to verify your account.`;
            document.body.appendChild(notice);

            // Auto-remove after 5 seconds
            setTimeout(() => {
              notice?.remove();
            }, 5000);
          }
        }

        setupSocialButtons() {
          const googleLoginBtn = document.getElementById("googleLoginBtn");
          const googleSignupBtn = document.getElementById("googleSignupBtn");

          if (googleLoginBtn) {
            googleLoginBtn.addEventListener("click", async (e) => {
              e.preventDefault();
              console.log("Google Login button clicked");
              try {
                const firebaseUser = await loginWithGoogle();
                console.log("Google login successful:", firebaseUser.email);
                this.completeLogin(firebaseUser);
              } catch (error) {
                console.error("Google login error:", error);
                const friendlyMessage = getFriendlyErrorMessage(error);
                this.showError("loginPasswordError", friendlyMessage);
              }
            });
          } else {
            console.warn("googleLoginBtn not found in DOM");
          }

          if (googleSignupBtn) {
            googleSignupBtn.addEventListener("click", async (e) => {
              e.preventDefault();
              console.log("Google Signup button clicked");
              try {
                const firebaseUser = await loginWithGoogle();
                console.log("Google signup successful:", firebaseUser.email);
                // Show verification notice (Google accounts may be auto-verified)
                if (!firebaseUser.emailVerified) {
                  this.showVerificationNotice();
                }
                setTimeout(() => {
                  this.completeLogin(firebaseUser);
                }, firebaseUser.emailVerified ? 0 : 2000);
              } catch (error) {
                console.error("Google signup error:", error);
                const friendlyMessage = getFriendlyErrorMessage(error);
                this.showError("signupEmailError", friendlyMessage);
              }
            });
          } else {
            console.warn("googleSignupBtn not found in DOM");
          }
        }

        setupPasswordReset() {
          const modal = document.getElementById("passwordResetModal");
          const closeBtn = document.getElementById("closePasswordResetBtn");
          const backToLoginBtn = document.getElementById("backToLoginBtn");
          const form = document.getElementById("passwordResetForm");
          const resetDoneBtn = document.getElementById("resetDoneBtn");

          // Find "Forgot password?" links
          const forgotPasswordLinks = document.querySelectorAll(
            "a.form-link[href='#']",
          );
          forgotPasswordLinks.forEach((link) => {
            if (link.textContent.toLowerCase().includes("forgot")) {
              link.addEventListener("click", (e) => {
                e.preventDefault();
                this.openPasswordResetModal();
              });
            }
          });

          // Close modal handlers
          closeBtn.addEventListener("click", () => {
            this.closePasswordResetModal();
          });

          backToLoginBtn.addEventListener("click", (e) => {
            e.preventDefault();
            this.closePasswordResetModal();
          });

          resetDoneBtn.addEventListener("click", () => {
            this.closePasswordResetModal();
          });

          // Form submission
          form.addEventListener("submit", async (e) => {
            e.preventDefault();
            await this.handlePasswordResetSubmit();
          });

          // Close modal when clicking overlay
          const overlay = modal.querySelector(".password-reset-overlay");
          overlay.addEventListener("click", () => {
            this.closePasswordResetModal();
          });

          // Prevent modal close when clicking inside card
          modal
            .querySelector(".password-reset-card")
            .addEventListener("click", (e) => {
              e.stopPropagation();
            });
        }

        openPasswordResetModal() {
          const modal = document.getElementById("passwordResetModal");
          const form = document.getElementById("passwordResetForm");
          const successMessage = document.getElementById("resetSuccessMessage");

          // Reset form
          form.reset();
          document.getElementById("resetEmailError").textContent = "";
          document.getElementById("resetEmailError").classList.remove("show");

          // Hide success message
          successMessage.style.display = "none";
          form.style.display = "block";

          // Show modal with animation
          modal.style.display = "flex";
          setTimeout(() => {
            document.getElementById("resetEmail").focus();
          }, 100);
        }

        closePasswordResetModal() {
          const modal = document.getElementById("passwordResetModal");
          modal.style.display = "none";
        }

        async handlePasswordResetSubmit() {
          const email = document.getElementById("resetEmail").value.trim();
          const errorEl = document.getElementById("resetEmailError");
          const form = document.getElementById("passwordResetForm");
          const successMessage = document.getElementById("resetSuccessMessage");
          const submitBtn = document.getElementById("resetSubmitBtn");

          // Clear previous errors
          errorEl.textContent = "";
          errorEl.classList.remove("show");

          // Validate email
          if (!email) {
            errorEl.textContent = "Email is required";
            errorEl.classList.add("show");
            return;
          }

          if (!this.validateEmail(email)) {
            errorEl.textContent = "Please enter a valid email";
            errorEl.classList.add("show");
            return;
          }

          try {
            // Disable submit button and show loading state
            submitBtn.disabled = true;
            submitBtn.innerHTML =
              '<i class="fa-solid fa-spinner fa-spin" style="margin-right: 8px;"></i>Sending...';

            // Send password reset email
            await resetPassword(email);

            // Show success message
            form.style.display = "none";
            successMessage.style.display = "block";

            console.log("Password reset email sent to:", email);
          } catch (error) {
            console.error("Password reset error:", error);
            errorEl.textContent = error.message || "Failed to send reset email";
            errorEl.classList.add("show");
          } finally {
            // Re-enable submit button
            submitBtn.disabled = false;
            submitBtn.innerHTML = "Send Reset Link";
          }
        }

        simulateGoogleLogin() {
          // Replaced with real Firebase Google login in setupSocialButtons()
        }

        simulateGoogleSignup() {
          // Replaced with real Firebase Google login in setupSocialButtons()
        }

        showError(elementId, message) {
          const errorEl = document.getElementById(elementId);
          if (errorEl) {
            errorEl.textContent = message;
            errorEl.classList.add("show");
          }
        }

        clearErrors(prefix) {
          document
            .querySelectorAll(`.form-error[id*="${prefix}"]`)
            .forEach((el) => {
              el.classList.remove("show");
              el.textContent = "";
            });
        }
      }

      const authManager = new AuthManager();
    </script>
  </body>
</html>
