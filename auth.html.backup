<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — PromptVerse</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="style.css" />
    <style>
      /* ===== Auth Page ===== */
      .auth-wrapper {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }

      .auth-container {
        width: 100%;
        max-width: 420px;
        padding: 24px;
        z-index: 10;
      }

      .auth-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(var(--glass-blur));
        -webkit-backdrop-filter: blur(var(--glass-blur));
        box-shadow: var(--glass-shadow);
        border-radius: 28px;
        padding: 40px;
        animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      }

      @keyframes slideUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .auth-header {
        text-align: center;
        margin-bottom: 32px;
      }

      .auth-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin-bottom: 16px;
      }

      .auth-logo i {
        font-size: 1.4rem;
        background: var(--grad-brand);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      .auth-logo span {
        font-family: var(--font-display);
        font-size: 1.2rem;
        font-weight: 600;
        background: var(--grad-text);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      .auth-title {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 6px;
      }

      .auth-subtitle {
        color: var(--text-soft);
        font-size: 0.9rem;
      }

      /* Tabs */
      .auth-tabs {
        display: flex;
        gap: 12px;
        margin-bottom: 28px;
        background: var(--surface-alt);
        padding: 4px;
        border-radius: 12px;
      }

      .auth-tab-btn {
        flex: 1;
        padding: 10px 16px;
        border-radius: 10px;
        background: transparent;
        border: none;
        color: var(--text-soft);
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all var(--transition);
      }

      .auth-tab-btn.active {
        background: var(--white);
        color: var(--purple-deep);
        box-shadow: 0 4px 12px rgba(139, 92, 246, 0.15);
      }

      body.dark .auth-tab-btn.active {
        background: var(--surface);
        color: var(--pink);
      }

      /* Forms */
      .auth-form {
        display: none;
        animation: fadeIn 0.3s ease;
      }

      .auth-form.active {
        display: block;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      .form-group {
        margin-bottom: 18px;
      }

      .form-label {
        display: block;
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 8px;
        color: var(--text);
      }

      .form-input {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid var(--border-color);
        border-radius: 12px;
        background: var(--surface);
        color: var(--text);
        font-size: 0.95rem;
        transition:
          border-color var(--transition),
          box-shadow var(--transition);
      }

      .form-input:focus {
        border-color: var(--purple);
        box-shadow: 0 0 0 3px rgba(167, 139, 250, 0.1);
      }

      .form-input::placeholder {
        color: var(--text-soft);
      }

      body.dark .form-input {
        background: var(--surface);
        border-color: rgba(255, 255, 255, 0.1);
      }

      .form-error {
        color: #e11d48;
        font-size: 0.8rem;
        margin-top: 4px;
        display: none;
      }

      .form-error.show {
        display: block;
      }

      .form-options {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.9rem;
        margin-bottom: 20px;
        gap: 12px;
      }

      .checkbox-wrapper {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .checkbox-wrapper input {
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: var(--purple);
      }

      .checkbox-label {
        cursor: pointer;
        color: var(--text-soft);
      }

      .form-link {
        color: var(--purple-deep);
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        transition: color var(--transition);
      }

      .form-link:hover {
        color: var(--purple);
      }

      /* Buttons */
      .auth-btn {
        width: 100%;
        padding: 12px 24px;
        border-radius: var(--r-pill);
        font-weight: 600;
        font-size: 0.95rem;
        border: none;
        cursor: pointer;
        transition:
          transform var(--transition),
          box-shadow var(--transition);
        margin-bottom: 16px;
      }

      .auth-btn-primary {
        background: var(--grad-brand);
        color: #fff;
        box-shadow: 0 8px 24px rgba(167, 139, 250, 0.35);
      }

      .auth-btn-primary:hover {
        box-shadow: 0 12px 28px rgba(236, 72, 153, 0.4);
        transform: translateY(-2px);
      }

      .auth-btn-primary:active {
        transform: scale(0.98);
      }

      .auth-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 24px 0;
        color: var(--text-soft);
        font-size: 0.85rem;
      }

      .auth-divider::before,
      .auth-divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border-color);
      }

      .social-login {
        display: flex;
        gap: 12px;
        margin-bottom: 16px;
      }

      .social-btn {
        flex: 1;
        padding: 12px;
        border: 1.5px solid var(--border-color);
        border-radius: 12px;
        background: var(--surface);
        color: var(--text);
        font-size: 1rem;
        cursor: pointer;
        transition: all var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
      }

      .social-btn:hover {
        border-color: var(--purple);
        background: rgba(167, 139, 250, 0.06);
      }

      .auth-footer {
        text-align: center;
        font-size: 0.9rem;
        color: var(--text-soft);
      }

      .auth-footer a {
        color: var(--purple-deep);
        font-weight: 600;
        text-decoration: none;
      }

      .auth-footer a:hover {
        text-decoration: underline;
      }

      .back-home {
        text-align: center;
        margin-top: 20px;
      }

      .back-home a {
        color: var(--text-soft);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color var(--transition);
      }

      .back-home a:hover {
        color: var(--text);
      }

      /* Password Reset Modal */
      .password-reset-modal {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: fadeIn 0.3s ease;
      }

      .password-reset-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
      }

      .password-reset-card {
        position: relative;
        width: 100%;
        max-width: 400px;
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(var(--glass-blur));
        -webkit-backdrop-filter: blur(var(--glass-blur));
        box-shadow: var(--glass-shadow), 0 20px 60px rgba(139, 92, 246, 0.2);
        border-radius: 24px;
        padding: 40px;
        margin: 20px;
        animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .password-reset-close {
        position: absolute;
        top: 16px;
        right: 16px;
        width: 40px;
        height: 40px;
        border: none;
        background: rgba(139, 92, 246, 0.1);
        border-radius: 10px;
        color: var(--text);
        cursor: pointer;
        font-size: 1.2rem;
        transition: all var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .password-reset-close:hover {
        background: rgba(139, 92, 246, 0.2);
        transform: scale(1.1);
      }

      .password-reset-header {
        text-align: center;
        margin-bottom: 28px;
      }

      .password-reset-header i {
        font-size: 2.5rem;
        background: var(--grad-brand);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        display: block;
        margin-bottom: 12px;
      }

      .password-reset-header h2 {
        font-family: var(--font-display);
        font-size: 1.4rem;
        font-weight: 600;
        margin: 0 0 8px 0;
        color: var(--text);
      }

      .password-reset-header p {
        color: var(--text-soft);
        font-size: 0.9rem;
        margin: 0;
      }

      .password-reset-form {
        margin-bottom: 24px;
      }

      .password-reset-success {
        text-align: center;
      }

      .password-reset-success i {
        font-size: 3rem;
        color: #10b981;
        display: block;
        margin-bottom: 16px;
        animation: popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      @keyframes popIn {
        0% {
          transform: scale(0.5);
          opacity: 0;
        }
        70% {
          transform: scale(1.1);
        }
        100% {
          transform: scale(1);
          opacity: 1;
        }
      }

      .password-reset-success h3 {
        font-family: var(--font-display);
        font-size: 1.3rem;
        font-weight: 600;
        margin: 0 0 12px 0;
        color: var(--text);
      }

      .password-reset-success p {
        color: var(--text-soft);
        font-size: 0.95rem;
        margin: 0;
        line-height: 1.5;
      }

      .password-reset-footer {
        text-align: center;
        font-size: 0.9rem;
        color: var(--text-soft);
      }

      .password-reset-footer a {
        color: var(--purple-deep);
        font-weight: 600;
        text-decoration: none;
      }

      .password-reset-footer a:hover {
        text-decoration: underline;
      }

      @media (max-width: 640px) {
        .auth-container {
          padding: 16px;
        }
        .auth-card {
          padding: 24px;
          border-radius: 20px;
        }
        .auth-title {
          font-size: 1.3rem;
        }
        .password-reset-card {
          padding: 24px;
          border-radius: 16px;
        }
      }
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
